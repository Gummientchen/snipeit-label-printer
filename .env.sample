# Snipe-IT Connection Settings
# The base URL of your Snipe-IT instance (do not include the /api/... path)
SNIPEIT_URL=YOUR_SNIPEIT_URL
# Your Snipe-IT API Bearer Token (generated in Snipe-IT > Admin > API Tokens)
SNIPEIT_API_KEY=YOUR_SNIPEIT_API_KEY

# Printer Settings
# The exact name of your Zebra printer as it appears in Windows Printer settings
PRINTER_NAME=ZDesigner ZD420-300dpi ZPL
# Absolute path to the Ghostscript command-line executable (gswin64c.exe)
# Required on Windows for direct PDF printing. Make sure to escape backslashes or use quotes if needed.
GHOSTSCRIPT_PATH=C:\Program Files\gs\gs10.05.1\bin\gswin64c.exe

# Label Size & Layout Settings (in centimeters)
LABEL_WIDTH_CM=7.0
LABEL_HEIGHT_CM=3.2

# Custom Field Settings
# The internal database field name in Snipe-IT (starts with _snipeit_)
TARGET_CUSTOM_FIELD_API_NAME=_snipeit_klasse_3
# The display name of the field printed on the label (e.g. Klasse, Room, etc.)
TARGET_CUSTOM_FIELD_LABEL_DISPLAY_NAME=Klasse

# Scale & Offset Settings
# Scale factor for small label generation (e.g., 0.7 for 70%)
SMALL_LABEL_SCALE_FACTOR=0.7

# Print Offset Adjustments (in millimeters)
# Positive X shifts content to the RIGHT. Positive Y shifts content UP.
PRINT_X_OFFSET_MM_NORMAL=24
PRINT_Y_OFFSET_MM_NORMAL=0
PRINT_X_OFFSET_MM_SMALL=24
PRINT_Y_OFFSET_MM_SMALL=0

# Manually push the QR code down by a configurable millimeter amount (positive value shifts DOWN)
QR_CODE_DOWN_OFFSET_MM=0.0

# Debug & Output Settings
# Set to True to open the PDF in the default PDF viewer instead of printing directly
DEBUG_OPEN_PDF_INSTEAD_OF_PRINTING=False
# Set to True for verbose console logging and tracebacks
VERBOSE_OUTPUT=False
